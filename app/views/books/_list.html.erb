<%# locals: (books: [], show_author: true) %>
<div class="space-y-4">
  <% books.each do |book| %>
    <%= turbo_frame_tag "book_#{book.id}", 
        src: card_book_path(book), 
        loading: "lazy",
        class: "block" do %>
      <%= render "book_skeleton" %>
    <% end %>
  <% end %>
</div>
